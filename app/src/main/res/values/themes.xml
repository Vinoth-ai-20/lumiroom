<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme (used for non-Compose views e.g. splash screen) -->
    <style name="Theme.Lumiroom" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme (applies before Compose takes over) -->
    <style name="Theme.Lumiroom.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D0D0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Lumiroom</item>
    </style>
</resources>
